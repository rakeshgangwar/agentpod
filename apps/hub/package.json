{
  "name": "@agentpod/hub",
  "version": "0.1.0",
  "description": "Agentpod Management API - orchestrates projects, containers, and credentials",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external cpu-features --external ssh2",
    "test": "bun test tests/unit && bun test tests/integration",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@agentpod/agents": "workspace:*",
    "@agentpod/contract": "workspace:*",
    "@agentpod/tsconfig": "workspace:*",
    "@agentpod/types": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "@iarna/toml": "^2.2.5",
    "@opencode-ai/sdk": "^1.17.11",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@types/dockerode": "^4.0.1",
    "better-auth": "^1.6.22",
    "dockerode": "^4.0.12",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.27",
    "isomorphic-git": "^1.38.5",
    "nanoid": "^5.1.16",
    "postgres": "^3.4.9",
    "superjson": "^2.2.6",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  }
}
